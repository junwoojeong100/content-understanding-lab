# Azure AI Content Understanding (Microsoft Foundry) 연결 설정
# infra/setup_azure.sh 를 실행하면 이 값들이 .env 에 자동으로 채워집니다.

# setup/teardown 이 같은 Azure 대상을 안전하게 재사용하기 위한 리소스 정체성
AZURE_SUBSCRIPTION_ID=
AZURE_RESOURCE_GROUP=rg-trade-content-understanding
AZURE_LOCATION=eastus2
AZURE_ACCOUNT_NAME=
AZURE_PROJECT_NAME=

# Foundry(=AIServices) 리소스 엔드포인트. 예) https://my-foundry.services.ai.azure.com/
CONTENTUNDERSTANDING_ENDPOINT=

# API 키 (선택). 비워두면 DefaultAzureCredential(az login +
# 'Cognitive Services Content Understanding Owner' 역할) 로 인증합니다. (권장)
# setup_azure.sh 는 로컬 키 인증을 명시적으로 비활성화하므로 기본값은 비워둡니다.
CONTENTUNDERSTANDING_KEY=

# 커스텀 분석기 ID. 허용 형식: 영문/숫자/마침표/언더스코어/하이픈, 1~64자
WORK_ORDER_ANALYZER_ID=trade_work_order
TECHPACK_ANALYZER_ID=techpack_bom

# Foundry 에 배포한 모델 "배포 이름" (update_defaults 매핑용)
GPT_5_2_DEPLOYMENT=gpt-5.2
GPT_4_1_MINI_DEPLOYMENT=gpt-4.1-mini
TEXT_EMBEDDING_3_LARGE_DEPLOYMENT=text-embedding-3-large

# 커스텀 분석기가 참조할 Content Understanding 모델 ID (배포 이름이 아님)
COMPLETION_MODEL=gpt-5.2
EMBEDDING_MODEL=text-embedding-3-large
